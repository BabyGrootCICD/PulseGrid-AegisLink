# =============================================================================
# PulseGrid-AegisLink (AuraSync) Environment Variables
# =============================================================================

# =============================================================================
# Database
# =============================================================================

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://aurasync:aurasync_dev@localhost:5432/aurasync
POSTGRES_USER=aurasync
POSTGRES_PASSWORD=aurasync_dev
POSTGRES_DB=aurasync

# MongoDB Atlas
MONGODB_URI=mongodb://aurasync:aurasync_dev@localhost:27017/aurasync
MONGODB_DB=aurasync

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# =============================================================================
# Application
# =============================================================================

# API Gateway
API_PORT=8082
API_HOST=0.0.0.0

# SFU Server
SFU_PORT=8080
SFU_HOST=0.0.0.0

# MQTT Broker
MQTT_PORT=8081
MQTT_HOST=0.0.0.0
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=aurasync-client

# Web App
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# =============================================================================
# JWT & Authentication
# =============================================================================

JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# Web3
# =============================================================================

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Ethereum
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ETHEREUM_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_PROJECT_ID

# Wallet
PHANTOM_WALLET_URL=https://phantom.app
METAMASK_CHAIN_ID=1

# =============================================================================
# Age Verification
# =============================================================================

# Yoti
YOTI_CLIENT_SDK_ID=your_yoti_sdk_id
YOTI_API_ENDPOINT=https://api.yoti.com/sandbox/v3

# World ID (Worldcoin)
WORLDCOIN_APP_ID=your_worldcoin_app_id
WORLDCOIN_ACTION=verify-adult

# =============================================================================
# Infrastructure as Code
# =============================================================================

# Terraform
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_zone_id=
TF_VAR_cloudflare_api_token=
TF_VAR_supabase_access_token=
TF_VAR_supabase_project_id=
TF_VAR_supabase_db_password=
TF_VAR_mongodb_atlas_public_key=
TF_VAR_mongodb_atlas_private_key=
TF_VAR_mongodb_atlas_org_id=
TF_VAR_mongodb_atlas_project_id=
TF_VAR_redis_password=
TF_VAR_solana_rpc_url=
TF_VAR_ethereum_rpc_url=
TF_VAR_yoti_client_sdk_id=
TF_VAR_worldcoin_app_id=

# Pulumi
PULUMI_ACCESS_TOKEN=

# =============================================================================
# Choreo.dev
# =============================================================================

CHOREO_ORG_ID=
CHOREO_PROJECT_ID=
CHOREO_ENV_ID=

# =============================================================================
# Security
# =============================================================================

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Monitoring
# =============================================================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Development
# =============================================================================

NODE_ENV=development
DEBUG=*
