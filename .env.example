# Environment Variables

## Database
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
DATABASE_URL=postgresql://aurasync:aurasync_dev@localhost:5432/aurasync
MONGODB_URI=mongodb://aurasync:aurasync_dev@localhost:27017/aurasync

## MQTT
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=aurasync-client

## Web3
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
PHANTOM_WALLET_URL=https://phantom.app

## Age Verification
YOTI_CLIENT_SDK_ID=your_yoti_sdk_id
WORLDCON_ID=your_worldcoin_app_id

## JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

## API
API_PORT=8082
SFU_PORT=8080
MQTT_PORT=8081
